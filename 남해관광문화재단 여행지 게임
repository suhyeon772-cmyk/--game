<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>남해 여행지 그림 맞추기</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:"Malgun Gothic", sans-serif;
    text-align:center;
    background:linear-gradient(135deg,#e8f8e8,#f4fff4);
    min-height:100vh;
    padding:20px;
    overflow:hidden;
}

h1{
    color:#2e7d32;
    margin-bottom:10px;
}

p{
    margin-bottom:15px;
}

.info{
    display:flex;
    justify-content:center;
    gap:20px;
    margin-bottom:15px;
    font-size:18px;
    font-weight:bold;
    color:#1b5e20;
}

button{
    padding:10px 18px;
    border:none;
    border-radius:8px;
    background:#2e7d32;
    color:white;
    cursor:pointer;
    margin-bottom:20px;
    font-size:16px;
}

button:hover{
    background:#1b5e20;
}

#game{
    display:grid;
    grid-template-columns:repeat(4,150px);
    gap:12px;
    justify-content:center;
}

.card{
    width:150px;
    height:150px;
    perspective:1000px;
    cursor:pointer;
}

.inner{
    position:relative;
    width:100%;
    height:100%;
    transform-style:preserve-3d;
    transition:transform .5s;
}

.card.flipped .inner,
.card.matched .inner{
    transform:rotateY(180deg);
}

.front,
.back{
    position:absolute;
    width:100%;
    height:100%;
    border-radius:12px;
    backface-visibility:hidden;
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:10px;
    font-weight:bold;
    white-space:nowrap;
}

.front{
    background:#43a047;
    color:white;
}

.back{
    background:white;
    border:2px solid #43a047;
    transform:rotateY(180deg);
    color:#1b5e20;
}

.matched .back{
    background:#c8f7c5;
}

/* 폭죽 */
.confetti{
    position:fixed;
    width:8px;
    height:8px;
    top:-10px;
    opacity:0.8;
    animation: fall linear forwards;
}

@keyframes fall{
    to{
        transform: translateY(110vh) rotate(720deg);
        opacity:1;
    }
}

#resultBox{
    margin-top:20px;
    display:none;
}

#videoBtn{
    background:#ff6f00;
}

#videoBtn:hover{
    background:#e65100;
}
</style>
</head>

<body>

<h1>남해 여행지 그림 맞추기</h1>
<p>같은 여행지 카드를 찾아 모두 맞춰보세요!</p>

<div class="info">
    <div id="attempts">시도: 0</div>
    <div id="timer">시간: 0초</div>
</div>

<button onclick="startGame()">새 게임</button>

<div id="game"></div>

<div id="resultBox">
    <h2>🎉 성공했습니다!</h2>
    <button id="videoBtn" onclick="openVideo()">
        관광지 영상 확인하기
    </button>
</div>

<script>

const items = [
    "🌉 남해대교",
    "🌾 다랭이마을",
    "🏘️ 독일마을",
    "🏖️ 상주은모래비치",
    "🌊 설리스카이워크",
    "🌳 이순신순국공원",
    "🌅 금산보리암",
    "🐟 물건방조어부림"
];

let firstCard = null;
let secondCard = null;
let lockBoard = false;
let attempts = 0;
let matchedPairs = 0;
let timer = 0;
let timerInterval;

function shuffle(array){
    for(let i=array.length-1;i>0;i--){
        const j=Math.floor(Math.random()*(i+1));
        [array[i],array[j]]=[array[j],array[i]];
    }
}

function startTimer(){
    clearInterval(timerInterval);
    timer = 0;

    timerInterval = setInterval(()=>{
        timer++;
        document.getElementById("timer").textContent =
        "시간: " + timer + "초";
    },1000);
}

function startGame(){

    document.getElementById("resultBox").style.display="none";

    const game = document.getElementById("game");
    game.innerHTML = "";

    firstCard = null;
    secondCard = null;
    lockBoard = false;

    attempts = 0;
    matchedPairs = 0;

    document.getElementById("attempts").textContent = "시도: 0";

    let cards = [...items, ...items];
    shuffle(cards);

    cards.forEach(text=>{
        const card = document.createElement("div");
        card.className = "card";
        card.dataset.value = text;

        card.innerHTML = `
        <div class="inner">
            <div class="front">남해 여행지</div>
            <div class="back">${text}</div>
        </div>
        `;

        card.addEventListener("click",()=>{
            flipCard(card);
        });

        game.appendChild(card);
    });

    startTimer();
}

function flipCard(card){

    if(lockBoard) return;
    if(card===firstCard) return;
    if(card.classList.contains("matched")) return;

    card.classList.add("flipped");

    if(!firstCard){
        firstCard = card;
        return;
    }

    secondCard = card;

    attempts++;

    document.getElementById("attempts").textContent =
    "시도: " + attempts;

    checkMatch();
}

function checkMatch(){

    const isMatch =
    firstCard.dataset.value === secondCard.dataset.value;

    if(isMatch){

        firstCard.classList.add("matched");
        secondCard.classList.add("matched");

        matchedPairs++;

        resetTurn();

        if(matchedPairs===8){
            clearInterval(timerInterval);
            document.getElementById("resultBox").style.display="block";
            launchConfetti(); // 🎉 폭죽 실행
        }

    }else{

        lockBoard = true;

        setTimeout(()=>{
            firstCard.classList.remove("flipped");
            secondCard.classList.remove("flipped");
            resetTurn();
        },900);
    }
}

function resetTurn(){
    firstCard = null;
    secondCard = null;
    lockBoard = false;
}

/* 🎥 영상 */
function openVideo(){
    window.open("https://youtu.be/gkR0igixgl0?si=PsR-y0iBGandY4HQ", "_blank");
}

/* 🎉 폭죽 효과 */
function launchConfetti(){
    for(let i=0;i<80;i++){
        const confetti = document.createElement("div");
        confetti.className = "confetti";
        confetti.style.left = Math.random()*100 + "vw";
        confetti.style.background = `hsl(${Math.random()*360},100%,50%)`;
        confetti.style.animationDuration = (Math.random()*2+2) + "s";
        document.body.appendChild(confetti);

        setTimeout(()=>{
            confetti.remove();
        },4000);
    }
}

startGame();

</script>

</body>
</html>
